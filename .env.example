NEXT_PUBLIC_APP_NAME="Opos App"

# Supabase, used only from Next server routes for aliases, attempts and exam sessions.
# Use the service_role secret key, not the publishable/anon key.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Optional content mirror. If question_packs has rows, the app reads them from Supabase.
# JSON files remain the canonical source and fallback.
CONTENT_SOURCE="auto"

# Admin area. This is not user management: it is a shared admin key.
ADMIN_SECRET=""

# GitHub content commits from the admin UI.
GITHUB_TOKEN=""
GITHUB_OWNER=""
GITHUB_REPO=""
GITHUB_BRANCH="main"

# Optional local fallback for admin saves during development.
ALLOW_LOCAL_CONTENT_WRITES="false"
